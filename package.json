{
  "name": "@steve-life/code-agent-sdk",
  "version": "0.0.1",
  "description": "Experimental multi-agent Codex orchestration SDK for coding workflows.",
  "license": "MIT",
  "author": "SteveLaiTVT",
  "keywords": [
    "codex",
    "agent",
    "multi-agent",
    "orchestration",
    "sdk",
    "coding-agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SteveLaiTVT/code-agent-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/SteveLaiTVT/code-agent-sdk/issues"
  },
  "homepage": "https://github.com/SteveLaiTVT/code-agent-sdk#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "agent:demo": "npm run build && node dist/examples/run-demo.js",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.125.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
